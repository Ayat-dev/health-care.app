<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinic.client.controller.DashboardController"
            prefWidth="900" prefHeight="580">

    <!-- Sidebar -->
    <left>
        <VBox spacing="4" style="-fx-padding:20 12; -fx-background-color:#1e3a5f; -fx-pref-width:200px;">
            <Label text="ClinicApp" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:white; -fx-padding:0 0 16 0;"/>
            <Button text="Tableau de bord" maxWidth="Infinity" style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-background-radius:6;"/>
            <Button text="Patients" maxWidth="Infinity" onAction="#goPatients"
                    style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-background-radius:6;"/>
            <Button text="Rendez-vous" maxWidth="Infinity" onAction="#goAppointments"
                    style="-fx-background-color:transparent; -fx-text-fill:#94a3b8; -fx-cursor:hand; -fx-background-radius:6;"/>
            <Separator style="-fx-padding:8 0;"/>
            <Button text="Déconnexion" maxWidth="Infinity" onAction="#logout"
                    style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-background-radius:6; -fx-cursor:hand;"/>
        </VBox>
    </left>

    <!-- Contenu -->
    <center>
        <VBox spacing="16" style="-fx-padding:24; -fx-background-color:#f1f5f9;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="welcomeLabel" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
                <Label fx:id="roleLabel" style="-fx-background-color:#dbeafe; -fx-text-fill:#1d4ed8; -fx-padding:2 8; -fx-background-radius:999; -fx-font-size:11px; -fx-font-weight:bold;"/>
            </HBox>
            <TextArea fx:id="logArea" prefHeight="200" editable="false"
                      style="-fx-background-color:white; -fx-background-radius:8; -fx-font-size:13px;"/>
        </VBox>
    </center>
</BorderPane>
