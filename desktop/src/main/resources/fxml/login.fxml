<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.clinic.client.controller.LoginController"
           style="-fx-background-color:#f1f5f9;"
           prefWidth="860" prefHeight="560">

    <VBox spacing="14" alignment="CENTER" maxWidth="380">
        <Label text="ClinicApp"
               style="-fx-font-size:32px; -fx-font-weight:bold; -fx-text-fill:#2563eb;"/>
        <Label text="Connexion à votre espace"
               style="-fx-text-fill:#64748b; -fx-font-size:14px;"/>

        <VBox spacing="10"
              style="-fx-background-color:white; -fx-padding:28; -fx-background-radius:12;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,.10),16,0,0,4);">
            <Label text="Nom d'utilisateur" style="-fx-font-size:13px; -fx-text-fill:#374151;"/>
            <TextField fx:id="username" promptText="ex: dr.martin"
                       style="-fx-pref-height:38px; -fx-background-radius:6;"/>
            <Label text="Mot de passe"
                   style="-fx-font-size:13px; -fx-text-fill:#374151; -fx-padding:4 0 0 0;"/>
            <PasswordField fx:id="password" promptText="••••••••"
                           style="-fx-pref-height:38px; -fx-background-radius:6;"/>
            <Button fx:id="loginBtn" text="Se connecter" maxWidth="Infinity"
                    style="-fx-background-color:#2563eb; -fx-text-fill:white; -fx-pref-height:40px;
                           -fx-background-radius:6; -fx-cursor:hand; -fx-font-size:14px; -fx-font-weight:bold;"/>
            <HBox alignment="CENTER">
                <ProgressIndicator fx:id="spinner" prefHeight="24" prefWidth="24" visible="false"/>
            </HBox>
            <Label fx:id="message" textFill="red" wrapText="true"
                   style="-fx-font-size:12px;" maxWidth="Infinity"/>
        </VBox>
    </VBox>
</StackPane>
